# Normalize line endings for cross-platform compatibility
* text=auto eol=lf

# Ensure JS files are always LF
*.js text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary
