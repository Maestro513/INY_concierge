ANTHROPIC_API_KEY=sk-ant-your-key-here

# UHC Provider Directory (Optum FLEX)
UHC_CLIENT_ID=your-client-id-here
UHC_CLIENT_SECRET=your-client-secret-here
UHC_PAYER_ID=hsid

# JWT Authentication (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your-secret-here

# SMS Provider: "twilio" (production) or "console" (dev — prints OTP to logs)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
