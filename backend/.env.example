ANTHROPIC_API_KEY=sk-ant-your-key-here

# Zoho CRM (member lookup)
ZOHO_CLIENT_ID=your-client-id-here
ZOHO_CLIENT_SECRET=your-client-secret-here
ZOHO_REFRESH_TOKEN=your-refresh-token-here

# Google APIs (geocoding + Places for provider search)
GOOGLE_API_KEY=your-google-api-key-here

# UHC Provider Directory (Optum FLEX)
UHC_CLIENT_ID=your-client-id-here
UHC_CLIENT_SECRET=your-client-secret-here
UHC_PAYER_ID=hsid

# Aetna Provider Directory (DaVinci Plan Net)
AETNA_CLIENT_ID=your-client-id-here
AETNA_CLIENT_SECRET=your-client-secret-here

# Aetna Real-Time Pharmacy Benefit Check (RTPBC)
# Subscribe at: https://developerportal.aetna.com → sandbox-realtimepharmacybenefitcheckapi-fhir
AETNA_RTPBC_CLIENT_ID=your-rtpbc-client-id-here
AETNA_RTPBC_CLIENT_SECRET=your-rtpbc-client-secret-here
# Sandbox URL (update after subscribing — check Swagger spec for exact path)
AETNA_RTPBC_BASE_URL=https://vteapif1.aetna.com/fhirdemo/v1/realtimepharmacybenefitcheckapi
AETNA_RTPBC_TOKEN_URL=https://vteapif1.aetna.com/fhirdemo/v1/fhirserver_auth/oauth2/token

# JWT Authentication (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your-secret-here
JWT_ACCESS_TTL=7200
JWT_REFRESH_TTL=2592000

# Admin panel secret (REQUIRED in production/staging)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=your-admin-secret-here

# Field-level encryption for PHI at rest (REQUIRED in production/staging)
# Generate with: python -c "from app.encryption import generate_key; print(generate_key())"
FIELD_ENCRYPTION_KEY=

# HMAC key for audit actor pseudonymization (REQUIRED in production/staging)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUDIT_HMAC_KEY=

# SMS Provider: "twilio" (production) or "console" (dev — prints OTP to logs)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Sentry error monitoring (optional, recommended for production)
SENTRY_DSN=

# App environment: development | staging | production
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated extra origins (insurancenyou.com always allowed in prod)
CORS_ORIGINS=

# Database paths (defaults to /data/ on Render persistent disk, local dir in dev)
STORE_DB_PATH=
DATA_DIR=

# CMS Marketplace API concurrency limit
CMS_API_CONCURRENCY=5

# Test account (dev/staging ONLY — disabled in production via config.py)
# Phone: enter this number to get a demo account without real SMS
# OTP: enter this code on the OTP screen to verify
# IMPORTANT: Choose unique values per environment, never reuse these examples
TEST_PHONE=
TEST_OTP=
