{
  "expo": {
    "name": "InsuranceNYou Concierge",
    "slug": "iny-concierge",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "insurancenyou",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.insurancenyou.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "InsuranceNYou needs speech recognition to understand your questions.",
        "NSMicrophoneUsageDescription": "InsuranceNYou needs your microphone to answer your questions by voice."
      }
    },
    "android": {
      "package": "com.insurancenyou.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "InsuranceNYou needs your microphone to answer your questions by voice.",
          "speechRecognitionPermission": "InsuranceNYou needs speech recognition to understand your questions."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#7B3FBF",
          "defaultChannel": "medication-reminders"
        }
      ],
      "@sentry/react-native/expo"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b4b999b-025c-49c5-bd6f-75a82722f4c4"
      }
    }
  }
}
